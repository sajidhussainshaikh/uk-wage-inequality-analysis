    "# ==============================================================\n",
    "# SETUP - Load and clean ONS Annual Survey of Hours and Earnings\n",
    "# ==============================================================\n",
    "# Source: ONS ASHE Table 16.7a - Annual pay, gross, all employees (2025) \n",
    "# This cell imports required libraries, loads the raw Excel file,\n",
    "# and produces a clean dataset of 576+ unique sectors with valid\n",
    "# median pay and year-on-year change figures.\n",
    "\n",
    "import pandas as pd\n",
    "import os \n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "filepath = os.path.expanduser(\"~/Desktop/ONS_Annual_Pay_Gross_2025.xlsx\")\n",
    "df = pd.read_excel(filepath, sheet_name=\"All\", header=4)\n",
    "\n",
    "df_clean = df[['Description', 'Median', 'change']].copy()\n",
    "df_clean = df_clean.dropna(subset=['Median'])\n",
    "\n",
    "df_clean['Median'] = pd.to_numeric(df_clean['Median'], errors='coerce')\n",
    "df_clean = df_clean.dropna() \n",
    "\n",
    "print(f\"Dataset loaded: {df_clean.shape[0]} rows ready\")\n",
    "                   \n",
    "\n",
    "\n"
   ]
