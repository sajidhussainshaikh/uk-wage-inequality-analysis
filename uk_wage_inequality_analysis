    "# ============================================================\n",
    "# CHART 1 FINAL — UK Sectoral Pay Against National Median 2025\n",
    "# ============================================================\n",
    "# Removes ALL EMPLOYEES aggregate row to show only genuine\n",
    "# sector comparisons. Saved to Desktop and published to GitHub.\n",
    "# Key finding: 10 of 20 broad sectors pay below the national\n",
    "# median of £32,890 — including Healthcare, Education, and\n",
    "# Agriculture. Financial and Insurance Activities shows both\n",
    "# the second highest pay AND the fastest growth at 14.1%.\n",
    "# ============================================================\n",
    "top_level_chart = top_level_sorted[top_level_sorted['Description'] != 'ALL EMPLOYEES']\n",
