    "# =======================================================\n",
    "# TOP-LEVEL SECTORS - Filter to broad industry categories\n",
    "# =======================================================\n",
    "# ONS uses All CAPS descriptions for top-level sector headings.\n",
    "# Filtering on str.isupper() isolates these 20 broad categories,\n",
    "# giving a clean economy-wide view without sub-sector noise.\n",
    "# These are the primary unit of analysis for this research.\n",
    "# =======================================================\n",
    "\n",
    "top_level = df_clean[df_clean['Description'].str.isupper()]\n",
    "print(top_level[['Description', 'Median', 'change']])\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n"
   ]
